# Copy this file to .env and fill in your values.
AWS_REGION=us-east-1

# Bedrock model IDs. Run `aws bedrock list-foundation-models --region $AWS_REGION`
# to confirm what is enabled in your account, then set the right IDs here.
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
GENERATION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Retrieval / chunking (defaults are fine to start)
TOP_K=4
CHUNK_SIZE=700
CHUNK_OVERLAP=100
